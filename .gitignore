# ════════════════════════════════════════════════════════════════════
# .gitignore — CRM Otron
# Catch-all defensivo para impedir vazamento de segredos e dados sensíveis
# ════════════════════════════════════════════════════════════════════

# ─── 🔐 SEGREDOS — NUNCA commit ────────────────────────────────────
.env
.env.local
.env.production
.env.development
.env.staging
.env.glitchtip
.env.*.local
**/.env
**/.env.local
**/.env.production
**/.env.development
**/.env.staging
**/.env.glitchtip
**/.env.*.local
# Permite o template público
!**/.env.example
!.env.example

# Certificados / chaves privadas
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
gerencianet-certs/
**/gerencianet-certs/
certs/
**/certs/

# Backups com dados de clientes
*.sql
*.sql.gz
*.dump
backups/
**/backups/

# ─── 📦 Build / dependências ──────────────────────────────────────
node_modules/
**/node_modules/
dist/
build/
**/dist/
**/build/
.next/
out/

# ─── 📊 Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
**/logs/

# ─── 💬 Sessões do WhatsApp (Baileys / WWebJS) ────────────────────
# CONTÉM CHAVES DE SESSÃO — VAZAMENTO = SEQUESTRO DA CONTA WHATSAPP
.wwebjs_auth/
**/.wwebjs_auth/
sessions/
**/sessions/
WWebJS/
**/WWebJS/
baileys_auth_info/
**/baileys_auth_info/

# ─── 📁 Uploads e mídia de clientes ───────────────────────────────
# Contém anexos enviados/recebidos via WhatsApp (PII)
backend/public/uploads/
**/public/uploads/
public/files/
**/public/files/

# ─── 🛠️ IDEs e SO ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ─── 🧪 Testes e coverage ─────────────────────────────────────────
coverage/
.nyc_output/
**/coverage/

# ─── 🐳 Docker runtime ────────────────────────────────────────────
# Volumes locais do docker-compose (postgres_data etc.)
postgres_data/
redis_data/

# ─── 📝 Artefatos temporários ─────────────────────────────────────
.tmp/
*.tmp
*.cache
.cache/

# ─── ⚙️ Configurações locais de máquina ───────────────────────────
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/tasks/
# Pastas de tooling de IA local (Antigravity, Gemini CLI etc.)
.agent/
.python-version
.nvmrc

# ─── 🔄 Migrations geradas (Sequelize) ────────────────────────────
# Já versionadas em backend/src/database/migrations
# nada a ignorar

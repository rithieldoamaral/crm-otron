NODE_ENV=development
BACKEND_URL=http://localhost
FRONTEND_URL=http://localhost:3000
PROXY_PORT=8080
PORT=8080

DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres_user
DB_PASS=change_me_strong_password
DB_NAME=crm_otron

# SEGURANÇA: gere segredos NOVOS e únicos para cada ambiente.
# Sugestão: openssl rand -base64 32
# NUNCA reutilize esses valores entre dev / staging / produção,
# e NUNCA commit valores reais nesse arquivo (.env.example é público).
JWT_SECRET=GENERATE_WITH_openssl_rand_base64_32
JWT_REFRESH_SECRET=GENERATE_WITH_openssl_rand_base64_32

# Redis: SEMPRE use senha em produção. Sem senha, qualquer um na rede acessa
# os jobs da Bull queue, que carregam PII (telefone, mensagens). Em produção,
# bind o Redis somente em rede interna ou use TLS.
REDIS_URI=redis://:CHANGE_ME_REDIS_PASSWORD@127.0.0.1:6379
REDIS_OPT_LIMITER_MAX=1
REDIS_OPT_LIMITER_DURATION=3000

USER_LIMIT=10000
CONNECTIONS_LIMIT=100000
CLOSED_SEND_BY_ME=true

GERENCIANET_SANDBOX=false
GERENCIANET_CLIENT_ID=your_gerencianet_client_id
GERENCIANET_CLIENT_SECRET=your_gerencianet_client_secret
GERENCIANET_PIX_CERT=path_to_certificate_p12
GERENCIANET_PIX_KEY=your_pix_key

MAIL_HOST="smtp.example.com"
MAIL_USER="contato@seusite.com"
MAIL_PASS="change_me"
MAIL_FROM="Recuperar Senha <contato@seusite.com>"
MAIL_PORT="465"

# Rastreamento de erros (opcional). Deixe em branco para desativar.
# Se você instalar o GlitchTip self-hosted (ver docs/DEPLOY_DOCKER_HOSTINGER.md,
# seção "Rastreamento de Erros"), cole aqui o DSN gerado pelo projeto criado lá.
SENTRY_DSN=
